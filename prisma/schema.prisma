generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum VehicleStatus {
  Available
  OnTrip
  InShop
  Retired
}

enum DriverStatus {
  Available
  OnTrip
  Suspended
  OffDuty
}

enum TripStatus {
  Draft
  Dispatched
  Completed
  Cancelled
}

enum MaintenanceStatus {
  Open
  Closed
}

model User {
  id          String   @id
  email       String   @unique
  name        String?
  role        String   @default("Driver")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdTrips Trip[]   @relation("TripCreatedBy")
  driver      Driver?
}

model Vehicle {
  id                Int               @id @default(autoincrement())
  registrationNumber String            @unique
  nameModel         String
  type              String
  maxLoadCapacity   Decimal           @db.Decimal(12, 2)
  odometer         Decimal           @default(0) @db.Decimal(12, 2)
  acquisitionCost   Decimal           @db.Decimal(12, 2)
  region           String?
  status           VehicleStatus      @default(Available)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  trips            Trip[]
  maintenanceLogs  MaintenanceLog[]
  fuelLogs         FuelLog[]
  expenses         Expense[]
}

model Driver {
  id                 Int           @id @default(autoincrement())
  userId             String?       @unique
  user               User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  name               String
  licenseNumber      String        @unique
  licenseCategory    String
  licenseExpiryDate  DateTime
  contactNumber      String
  status             DriverStatus  @default(Available)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  trips              Trip[]
}

model Trip {
  id              Int          @id @default(autoincrement())
  source          String
  destination     String
  vehicleId       Int
  driverId        Int
  cargoWeight     Decimal      @db.Decimal(12, 2)
  plannedDistance Decimal      @db.Decimal(12, 2)
  actualDistance  Decimal?     @db.Decimal(12, 2)
  fuelConsumed    Decimal?     @db.Decimal(12, 2)
  revenue         Decimal?     @db.Decimal(12, 2)
  status          TripStatus   @default(Draft)
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdById     String
  createdBy       User         @relation("TripCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver          Driver       @relation(fields: [driverId], references: [id], onDelete: Restrict)
  fuelLogs        FuelLog[]
  expenses        Expense[]
}

model MaintenanceLog {
  id              Int                @id @default(autoincrement())
  vehicleId       Int
  maintenanceType String
  description     String?
  cost            Decimal            @db.Decimal(12, 2)
  status          MaintenanceStatus  @default(Open)
  startDate       DateTime
  endDate         DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  vehicle         Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
}

model FuelLog {
  id               Int       @id @default(autoincrement())
  vehicleId        Int
  tripId           Int?
  liters           Decimal   @db.Decimal(12, 2)
  cost             Decimal   @db.Decimal(12, 2)
  logDate          DateTime
  odometerReading  Decimal?  @db.Decimal(12, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  trip             Trip?     @relation(fields: [tripId], references: [id], onDelete: SetNull)
}

model Expense {
  id            Int       @id @default(autoincrement())
  vehicleId     Int
  tripId        Int?
  expenseType   String
  amount        Decimal   @db.Decimal(12, 2)
  expenseDate   DateTime
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  trip          Trip?     @relation(fields: [tripId], references: [id], onDelete: SetNull)
}